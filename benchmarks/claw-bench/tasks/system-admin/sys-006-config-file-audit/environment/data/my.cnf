[mysqld]
user = mysql
pid-file = /var/run/mysqld/mysqld.pid
socket = /var/run/mysqld/mysqld.sock
datadir = /var/lib/mysql

# Security issue: binding to all interfaces
bind-address = 0.0.0.0

# Security issue: local infile enabled
local-infile = 1

# Security issue: symbolic links enabled
symbolic-links = 1

# Security issue: no password validation plugin
# validate_password is not loaded

# Security issue: general query log in accessible location
general_log = 1
general_log_file = /var/log/mysql/query.log

# Security issue: no SSL required
# require_secure_transport = ON

# Performance settings
max_connections = 200
key_buffer_size = 256M
innodb_buffer_pool_size = 1G

# Security issue: old password format
old_passwords = 1

# Security issue: skip grant tables (extremely dangerous)
# skip-grant-tables

# Logging
log_error = /var/log/mysql/error.log
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
