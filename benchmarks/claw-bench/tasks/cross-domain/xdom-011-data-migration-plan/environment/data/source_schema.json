{
  "table": "customers",
  "fields": [
    {"name": "cust_id", "type": "integer", "primary_key": true, "nullable": false},
    {"name": "full_name", "type": "varchar(200)", "nullable": false},
    {"name": "email_addr", "type": "varchar(150)", "nullable": false, "unique": true},
    {"name": "phone", "type": "varchar(20)", "nullable": true},
    {"name": "addr_line1", "type": "varchar(200)", "nullable": true},
    {"name": "addr_line2", "type": "varchar(200)", "nullable": true},
    {"name": "city", "type": "varchar(100)", "nullable": true},
    {"name": "state_code", "type": "char(2)", "nullable": true},
    {"name": "zip", "type": "varchar(10)", "nullable": true},
    {"name": "created", "type": "varchar(20)", "nullable": false},
    {"name": "status", "type": "integer", "nullable": false, "comment": "0=inactive, 1=active, 2=suspended"},
    {"name": "total_orders", "type": "integer", "nullable": true},
    {"name": "notes", "type": "text", "nullable": true}
  ]
}
