  },
  {
    "id": "rule_4",
    "name": "Purchase Tracking",
    "condition": {"type": "purchase"},
    "action": "track_purchase"
  },
  {
    "id": "rule_5",
    "name": "API Error Logging",
    "condition": {"type": "error", "source": "api"},
    "action": "log_api_error"
  },
  {
    "id": "rule_6",
    "name": "Any Error Notify Admin",
    "condition": {"type": "error"},
    "action": "notify_admin"
  }
