cff-version: 1.2.0
message: "If you use WildClawBench in your research, please cite it using the metadata below."
title: "WildClawBench"
type: software
license: MIT
abstract: "WildClawBench is an in-the-wild benchmark for AI agents in the OpenClaw environment, designed to evaluate end-to-end agent performance across 60 tasks spanning productivity, coding, social interaction, search, creative synthesis, and safety alignment."
repository-code: "https://github.com/InternLM/WildClawBench"
url: "https://github.com/InternLM/WildClawBench"
keywords:
  - AI agents
  - benchmark
  - evaluation
  - OpenClaw
  - multimodal agents
