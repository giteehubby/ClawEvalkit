# =============================================================================
# ClawEvalKit Base Image - NanoBotAgent Runtime
# =============================================================================
# Minimal base with NanoBotAgent dependencies.
# This image is used by: pinchbench, agentbench, clawbench_official, zclawbench
#
# Build: docker build -f docker/Dockerfile.base -t clawbase-nanobot:v1 .
# =============================================================================

FROM python:3.11-slim

# Avoid interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

WORKDIR /root

# Install minimal system tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install NanoBotAgent core dependencies
RUN pip install --no-cache-dir \
    -i https://pypi.org/simple/ \
    --trusted-host pypi.org \
    litellm \
    loguru \
    rich \
    tiktoken \
    pydantic-settings \
    ddgs \
    readability-lxml \
    numpy \
    matplotlib \
    pillow \
    opencv-python \
    openpyxl \
    pdfplumber \
    scipy \
    httpx

# =============================================================================
# NOTE: OpenClawPro should be mounted at /root/OpenClawPro at runtime:
#   docker run -v /path/to/OpenClawPro:/root/OpenClawPro:rw ...
# =============================================================================

# Add OpenClawPro to PYTHONPATH so 'harness' and 'nanobot' packages are importable
ENV PYTHONPATH=/root/OpenClawPro

# Working directory for task execution
WORKDIR /workspace

CMD ["/bin/bash"]
