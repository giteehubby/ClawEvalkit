#!/bin/bash
# Simple timeout wrapper for macOS
# Usage: timeout <seconds> <command> [args...]

if [ $# -lt 2 ]; then
    echo "Usage: timeout <seconds> <command> [args...]" >&2
    exit 1
fi

seconds=$1
shift

# Use perl for timeout on macOS
exec perl -e 'alarm shift @ARGV; exec @ARGV' "$seconds" "$@"
