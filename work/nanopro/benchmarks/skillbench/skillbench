#!/usr/bin/env python3
"""
SkillBench CLI

Usage:
    skillbench verify <scorecard-url>
    skillbench run --pack <pack> --skill <skill>
"""
import sys
import os

# Add repo root to path
repo_root = os.path.dirname(os.path.abspath(__file__))
if repo_root not in sys.path:
    sys.path.insert(0, repo_root)

def main():
    if len(sys.argv) < 2:
        print("Usage: skillbench <command> [options]")
        print()
        print("Commands:")
        print("  verify <url>    Verify a scorecard signature")
        print("  run             Run benchmark (see --help)")
        return 1

    command = sys.argv[1]

    if command == "verify":
        sys.argv = [sys.argv[0]] + sys.argv[2:]
        from harness.verify_cli import main as verify_main
        return verify_main()

    elif command == "run":
        sys.argv = [sys.argv[0]] + sys.argv[2:]
        from harness.cli import main as cli_main
        cli_main()
        return 0

    else:
        print(f"Unknown command: {command}")
        return 1

if __name__ == "__main__":
    sys.exit(main())
