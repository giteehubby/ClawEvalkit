{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillbench.dev/schemas/scorecard.v1.json",
  "title": "Skill Scorecard v1",
  "description": "Machine-readable skill evaluation output for marketplaces and integrations",
  "type": "object",
  "required": ["schema_version", "skill", "run", "suite", "metrics"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Scorecard schema version"
    },
    "skill": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique skill identifier (slug)"
        },
        "name": {
          "type": "string",
          "description": "Human-readable skill name"
        },
        "version": {
          "type": ["string", "null"],
          "description": "Skill version if available"
        },
        "artifact_digest": {
          "type": ["string", "null"],
          "description": "SHA-256 hash of skill artifact for integrity verification"
        }
      }
    },
    "run": {
      "type": "object",
      "required": ["run_id", "executed_at", "runner_version"],
      "properties": {
        "run_id": {
          "type": "string",
          "description": "Unique identifier for this evaluation run"
        },
        "executed_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of evaluation"
        },
        "runner_version": {
          "type": "string",
          "description": "Version of the evaluation runner"
        },
        "agent": {
          "type": ["string", "null"],
          "description": "Agent used for evaluation (e.g., 'claude-sonnet-4-20250514')"
        },
        "execution_mode": {
          "type": "string",
          "enum": ["local", "docker", "hosted"],
          "description": "Execution environment"
        }
      }
    },
    "suite": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Suite identifier (e.g., 'core-bugfix')"
        },
        "version": {
          "type": "string",
          "description": "Suite version"
        },
        "task_count": {
          "type": "integer",
          "description": "Number of tasks in suite"
        },
        "categories": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Bug/task categories covered"
        }
      }
    },
    "baseline": {
      "type": "object",
      "description": "Baseline comparison reference",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["no-skill", "previous-version", "other-skill"],
          "description": "What the skill was compared against"
        },
        "profile_id": {
          "type": ["string", "null"],
          "description": "Reference to baseline profile if applicable"
        },
        "digest": {
          "type": ["string", "null"],
          "description": "Baseline artifact digest for reproducibility"
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["reliability", "efficiency"],
      "properties": {
        "reliability": {
          "type": "object",
          "properties": {
            "baseline": {"type": "number", "minimum": 0, "maximum": 1},
            "augmented": {"type": "number", "minimum": 0, "maximum": 1},
            "delta": {"type": "number", "minimum": -1, "maximum": 1},
            "tasks_passed_baseline": {"type": "integer"},
            "tasks_passed_augmented": {"type": "integer"},
            "total_tasks": {"type": "integer"}
          }
        },
        "efficiency": {
          "type": "object",
          "properties": {
            "baseline_avg_ms": {"type": ["number", "null"]},
            "augmented_avg_ms": {"type": ["number", "null"]},
            "delta_ms": {"type": ["number", "null"]}
          }
        },
        "robustness": {
          "type": ["object", "null"],
          "description": "Robustness metrics if perturbation tests were run"
        },
        "legibility": {
          "type": "object",
          "properties": {
            "explicit_error_rate": {"type": ["number", "null"]},
            "silent_failure_rate": {"type": ["number", "null"]}
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "Human-readable summary for display",
      "properties": {
        "headline": {
          "type": "string",
          "description": "One-sentence summary"
        },
        "recommendation": {
          "type": ["string", "null"],
          "description": "Optional recommendation for skill author"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "description": "References to related artifacts",
      "properties": {
        "profile_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL to HTML profile"
        },
        "traces_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL to full execution traces"
        },
        "profile_digest": {
          "type": ["string", "null"],
          "description": "SHA-256 of generated profile HTML"
        },
        "traces_digest": {
          "type": ["string", "null"],
          "description": "SHA-256 of traces archive"
        }
      }
    },
    "signature": {
      "type": ["object", "null"],
      "description": "Optional cryptographic signature for verification",
      "properties": {
        "algorithm": {"type": "string"},
        "signer": {"type": "string"},
        "value": {"type": "string"}
      }
    }
  }
}
