{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillBench Report",
  "type": "object",
  "required": ["task_pack", "timestamp"],
  "properties": {
    "task_pack": { "type": "string" },
    "description": { "type": "string" },
    "timestamp": { "type": "string" },
    "baseline": { "$ref": "#/$defs/section" },
    "augmented": { "$ref": "#/$defs/section" },
    "profile": { "type": ["object", "null"] },
    "delta": {
      "type": ["object", "null"],
      "properties": {
        "success_rate": { "type": ["number", "null"] },
        "avg_runtime_s": { "type": ["number", "null"] },
        "passed": { "type": ["number", "null"] },
        "task_failed": { "type": ["number", "null"] }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "section": {
      "type": ["object", "null"],
      "properties": {
        "aggregate": { "$ref": "#/$defs/aggregate" },
        "tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/task" }
        }
      },
      "additionalProperties": true
    },
    "aggregate": {
      "type": "object",
      "properties": {
        "total": { "type": "integer" },
        "executed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" },
        "passed": { "type": "integer" },
        "task_failed": { "type": "integer" },
        "success_rate": { "type": ["number", "null"] },
        "avg_runtime_s": { "type": ["number", "null"] }
      },
      "additionalProperties": true
    },
    "task": {
      "type": "object",
      "properties": {
        "task_id": { "type": "string" },
        "mode": { "type": "string" },
        "status": { "type": "string" },
        "output": { "type": "string" },
        "result": { "type": ["object", "null"] }
      },
      "additionalProperties": true
    }
  }
}
