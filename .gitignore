# Large data files (benchmark data that should be downloaded, not committed)
# These are typically downloaded at runtime; do not track them if untracked
work/nanopro/benchmarks/**/environment/*.zip
work/nanopro/benchmarks/**/environment/*.tar.gz
work/nanopro/benchmarks/**/environment/*.mp4
work/nanopro/benchmarks/**/environment/*.pdf

# Embedding indexes (regenerate at runtime)
work/nanopro/benchmarks/**/skill_matcher/indexes/embeddings.npy
work/nanopro/benchmarks/**/skills-research/skill_embeddings*.npy
work/nanopro/benchmarks/**/skills-research/skill_embeddings*.npz

